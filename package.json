  "private": true,
  "description": "Hệ thống tuyển dụng tự trị sử dụng Multi-Agent AI — monorepo (scaffold).",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev:dashboard": "pnpm --filter dashboard dev",
