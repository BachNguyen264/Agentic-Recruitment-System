# ============================================================================
#  .env.example — MẪU cấu hình. Copy thành `.env` rồi điền giá trị thật.
#  `.env` đã được gitignore — TUYỆT ĐỐI không commit secret.
#
#  CHECKLIST tài khoản managed (PRD §6 · plan §5) — đăng ký & lấy thông tin:
#    [ ] Neon          https://neon.tech         → Connection string (Pooled)
#    [ ] Upstash Redis https://upstash.com       → rediss:// URL (TLS) + REST URL/Token
#    [ ] Qdrant Cloud  https://cloud.qdrant.io   → Cluster URL + API key
#    [ ] Langfuse      https://cloud.langfuse.com → Public + Secret key  (tùy chọn, phase sau)
#  Chưa có tài khoản? Chạy local: `make local-infra-up` rồi dùng mục LOCAL FALLBACK.
# ============================================================================

# ───────────────────────── App / Pipeline ─────────────────────────
APP_ENV=local
LOG_LEVEL=INFO
# Slice-01: đặt true để BẬT parser thật (chỉ node parser đọc cờ này). false -> parser stub.
ENABLE_LLM=false
# Bật endpoint DEV (vd /api/agents/resume-screener thủ công của 08a). Mặc định false — đường thật
# của Screener là magic-link form (08b). Chỉ bật khi test nội bộ; KHÔNG bật ở production.
ENABLE_DEV_ENDPOINTS=false

# ───────────────────────── LLM — OpenAI (slice-01 Parser, PRD §7.1) ─
# Lấy key tại https://platform.openai.com/api-keys. KHÔNG commit key thật.
OPENAI_API_KEY=
# Model cho Parser (rẻ, hỗ trợ structured output). Mặc định code: gpt-4.1-mini.
PARSER_MODEL=gpt-4.1-mini
# Embedding JD → Qdrant (slice-02a). 1536 chiều — đổi model thì đổi EMBEDDING_DIM + collection mới.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
# Ranker chấm rubric (slice-02b). ĐÃ CHỌN qua benchmark (01c): gpt-5-mini + reasoning_effort=low —
# chấm bám bằng chứng (vd điểm Tiếng Anh khớp TOEIC), nhất quán trên dữ liệu sạch. Đổi model: sửa 2
# dòng dưới. REASONING_EFFORT rỗng = non-reasoning (temperature=0); có giá trị = reasoning (bỏ temperature).
RANKER_MODEL=gpt-5-mini
RANKER_REASONING_EFFORT=low
# Ngưỡng điểm đạt (0..100) + dải sát ngưỡng (cờ near_threshold).
SCORE_PASS_THRESHOLD=60
SCORE_NEAR_BAND=10

# Ngưỡng & mốc thời gian (PRD §5 trụ cột 3 · §9 gate · §10 screener).
# Đọc từ env — tinh chỉnh thực nghiệm ở Chương 4 (PRD §18).
CONFIDENCE_THRESHOLD=0.6
SCREENER_DEADLINE_HOURS=72
SCREENER_REMINDER_HOURS=24
# Gốc URL frontend công khai để dựng magic-link Screener (08b): {FRONTEND_BASE_URL}/screening/{token}.
# Dev: dashboard Next chạy :3000. Đổi khi deploy (domain thật).
FRONTEND_BASE_URL=http://localhost:3000

# ───────────────────────── Email Service (Resend) ────────────────────────
# Scheduler gửi thư mời/từ chối (PRD §7.4). Lấy API key ở https://resend.com.
RESEND_API_KEY=
# Địa chỉ gửi. Test: onboarding@resend.dev (chỉ gửi được tới email tài khoản Resend của bạn
# khi domain CHƯA xác thực). Demo public: địa chỉ thuộc domain đã xác thực DNS trên Resend.
EMAIL_FROM=onboarding@resend.dev

# ───────────────────────── Postgres (Neon) ────────────────────────
# Dùng dạng SQLAlchemy async (driver asyncpg).
# QUAN TRỌNG (CLAUDE.md): asyncpg KHÔNG hiểu ?sslmode=... — BỎ mọi query param;
# SSL được bật trong code qua connect_args={"ssl": True}.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME

# ───────────────────────── Redis (Upstash) ────────────────────────
# rediss:// = TLS (bắt buộc với Upstash).
REDIS_URL=rediss://default:PASSWORD@HOST:6379
# REST API Upstash (chưa dùng ở scaffold — để trống cũng được):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ───────────────────────── Qdrant Cloud ───────────────────────────
QDRANT_URL=https://YOUR-CLUSTER.cloud.qdrant.io
QDRANT_API_KEY=
# Collection dùng chung JD + CV (payload "type" phân biệt). Mặc định code: cv_jd_embeddings.
QDRANT_COLLECTION=cv_jd_embeddings

# ───────────────────────── Langfuse (observability, phase sau) ─────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ───────────────────────── LOCAL FALLBACK (docker-compose.local.yml) ─
# Bỏ comment 3 dòng dưới (và comment các URL managed ở trên) khi chạy local:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/recruitment
# REDIS_URL=redis://localhost:6379
# QDRANT_URL=http://localhost:6333
